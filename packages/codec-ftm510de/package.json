{
  "name": "@fusiondeck/codec-ftm510de",
  "version": "0.0.0",
  "description": "RadioCodec plugin for the Yaesu FTM-510DE (SD-card .dat format) + Tier 1 ADMS-18 CSV export.",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@fusiondeck/core": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.9"
  }
}
