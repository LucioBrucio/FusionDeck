# FusionDeck server configuration — copy to .env (gitignored) and fill in.

# Server bind (optional)
# PORT=8787
# HOST=0.0.0.0

# --- RepeaterBook (live repeater data) ---
# The RepeaterBook API is gated since 2025. Request an approved application
# token (non-commercial is free but discretionary) at:
#   https://www.repeaterbook.com/api/token_request.php
# Without a token the server returns an error and the UI falls back to the
# bundled sample stations.
REPEATERBOOK_TOKEN=

# Initial geographic scope — RepeaterBook "rest of world" country name (§10).
REPEATERBOOK_COUNTRY=Italy

# RepeaterBook requires a User-Agent with an app identifier AND a contact email;
# generic agents are rejected. Use your own contact.
REPEATERBOOK_UA=FusionDeck/0.1 (+https://github.com/LucioBrucio/FusionDeck; you@example.com)
