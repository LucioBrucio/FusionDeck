{
  "name": "fusiondeck",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source, cross-platform tool to program Yaesu System Fusion radios — unifying live network discovery (RepeaterBook, WIRES-X, YSF) with radio memory programming.",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LucioBrucio/FusionDeck.git"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "rimraf": "^6.0.0",
    "turbo": "^2.9.18",
    "typescript": "~6.0.3"
  }
}
